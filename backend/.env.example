# PhishSecure Bahrain CTI Platform - Environment Configuration
# Copy to .env and configure with your API keys for accurate live results

# =============================================================================
# THREAT INTELLIGENCE API KEYS (For Maximum Accuracy)
# =============================================================================

# VirusTotal API (Highly Recommended - 95% accuracy)
# Get free API key: https://www.virustotal.com/gui/join-us
# Free: 4 requests/minute | Paid: 1000+ requests/minute
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AlienVault OTX API (Highly Recommended - Free)
# Get API key: https://otx.alienvault.com/
# Provides real-time threat intelligence pulses
OTX_API_KEY=your_otx_api_key_here

# Shodan API (Recommended for Infrastructure Monitoring)
# Get API key: https://www.shodan.io/
# Monitor Bahrain infrastructure and exposed services
SHODAN_API_KEY=your_shodan_api_key_here

# AbuseIPDB API (Optional but valuable)
# Get API key: https://www.abuseipdb.com/
# IP reputation and abuse reporting
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# =============================================================================
# CORE CTI PLATFORM SETTINGS
# =============================================================================

# Flask Environment
FLASK_ENV=production
DEBUG=false

# Database
DATABASE_PATH=./data/cti_database.db

# Continuous Monitoring
AUTO_START_MONITORING=true
MONITORING_INTERVAL_MINUTES=15

# Multi-Source Intelligence
ENABLE_MULTI_SOURCE=true
MAX_INDICATORS_PER_COLLECTION=1000

# =============================================================================
# BAHRAIN-SPECIFIC CONFIGURATION
# =============================================================================

# Threat Scoring Thresholds
HIGH_THREAT_THRESHOLD=70
HIGH_BAHRAIN_RELEVANCE_THRESHOLD=60

# Bahrain Monitoring Features
BAHRAIN_KEYWORD_MONITORING=true
ARABIC_SUPPORT=true
GOVERNMENT_MONITORING=true
BANKING_MONITORING=true
TELECOM_MONITORING=true

# =============================================================================
# ALERT CONFIGURATION
# =============================================================================

# Critical Alert Thresholds
CRITICAL_THREAT_SCORE=80
CRITICAL_BAHRAIN_SCORE=70

# Alert Categories
BANKING_ALERTS=true
GOVERNMENT_ALERTS=true
TELECOM_ALERTS=true
INFRASTRUCTURE_ALERTS=true

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Rate Limiting
API_RATE_LIMIT_SECONDS=2
CACHE_EXPIRY_HOURS=24

# Collection Intervals (minutes)
URLHAUS_INTERVAL=30
PHISHTANK_INTERVAL=60
OTX_INTERVAL=15
VIRUSTOTAL_INTERVAL=30
CERT_TRANSPARENCY_INTERVAL=60

# =============================================================================
# EXAMPLE CONFIGURATION FOR MAXIMUM ACCURACY
# =============================================================================

# Uncomment and configure these for best results:
# VIRUSTOTAL_API_KEY=abc123def456ghi789jkl012mno345pqr678stu901vwx234yz
# OTX_API_KEY=def456ghi789jkl012mno345pqr678stu901vwx234yz567abc123
# SHODAN_API_KEY=ghi789jkl012mno345pqr678stu901vwx234yz567abc123def456

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================

# Production URLs (update after deployment)
FRONTEND_URL=https://phishsecure-bahrain.vercel.app
BACKEND_URL=https://phishsecure-bahrain-cti.up.railway.app

# Security
SECRET_KEY=your_secure_secret_key_here_change_in_production
